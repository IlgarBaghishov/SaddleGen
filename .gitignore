# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.venv/
.eggs/
build/
dist/

# PyTorch / checkpoints
*.pt
*.pth
*.ckpt
*.safetensors

# Training outputs
checkpoints/
results/
logs/
wandb/
lightning_logs/

# Example-run artifacts: we keep light files (*.json, *.png, *.npz) committed as
# reference experiments, but exclude per-checkpoint heavy tensors (model weights,
# optimizer state, EMA shadow, RNG state, LR-scheduler state) and intermediate
# epoch checkpoints entirely.
**/checkpoint_epoch_*/
**/checkpoint_final/model.safetensors
**/checkpoint_final/optimizer.bin
**/checkpoint_final/scheduler.bin
**/checkpoint_final/ema.pt
**/checkpoint_final/random_states_*.pkl

# Data directories (datasets not tracked in git) anywhere in the tree,
# with an explicit exception for saddlegen/data/ (the source package).
data/
!saddlegen/data/
!saddlegen/data/**
# Re-exclude cache/build artifacts that the negation above would otherwise un-ignore.
saddlegen/data/**/__pycache__/
saddlegen/data/**/*.pyc
*.lmdb
*.h5
*.hdf5

# NERSC / SLURM
slurm*.log
slurm-*.out
*.err

# OS / editors
.DS_Store
.idea/
.vscode/

# Reference codes — kept locally for design reference; will be deleted before public release
other_codes/
